        { "value": "💬", "label": "💬 Chat bubble" },
        { "value": "🛍️", "label": "🛍️ Shopping bag" },
        { "value": "👋", "label": "👋 Waving hand" },
        { "value": "😊", "label": "😊 Smile" },
        { "value": "🤝", "label": "🤝 Handshake" },
        { "value": "⭐", "label": "⭐ Star" },
        { "value": "🚀", "label": "🚀 Rocket" },
        { "value": "💎", "label": "💎 Diamond" }
      ],
      "default": "💬"
    },
    {
      "type": "header",
      "content": "Button Appearance"
    },
    {
      "id": "button_color",
      "type": "color",
      "label": "Button Color",
      "default": "#25D366"
    },
    {
      "id": "button_size",
      "type": "range",
      "label": "Button Size",
      "min": 40,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "id": "button_position",
      "type": "select",
      "label": "Button Position",
      "options": [
        {
          "value": "bottom-right",
          "label": "Bottom Right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom Left"
        }
      ],
      "default": "bottom-right"
    },
    {
      "id": "bottom_spacing",
      "type": "range",
      "label": "Distance from Bottom",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "id": "side_spacing",
      "type": "range",
      "label": "Distance from Side",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Tooltip Settings"
    },
    {
      "id": "show_tooltip",
      "type": "checkbox",
      "label": "Show Tooltip",
      "info": "Show a text label next to the button",
      "default": false
    },
    {
      "id": "tooltip_text",
      "type": "text",
      "label": "Tooltip Text",
      "default": "Chat with us"
    },
    {
      "id": "tooltip_bg_color",
      "type": "color",
      "label": "Tooltip Background Color",
      "default": "#25D366"
    },
    {
      "id": "tooltip_text_color",
      "type": "color",
      "label": "Tooltip Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Visibility Settings"
    },
    {
      "id": "hide_on_mobile",
      "type": "checkbox",
      "label": "Hide on Mobile",
      "default": false
    },
    {
      "id": "hide_on_desktop",
      "type": "checkbox",
      "label": "Hide on Desktop",
      "default": false
    },
    {
      "type": "header",
      "content": "Animation Settings"
    },
    {
      "id": "enable_pulse",
      "type": "checkbox",
      "label": "Enable Pulse Animation",
      "info": "Adds a subtle pulse effect to attract attention",
      "default": true
    }
  ]
}
{% endschema %}
