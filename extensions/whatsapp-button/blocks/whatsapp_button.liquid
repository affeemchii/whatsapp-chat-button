        { "value": "1-us", "label": "🇺🇸 United States (+1)" },
        { "value": "1-ca", "label": "🇨🇦 Canada (+1)" },
        { "value": "44", "label": "🇬🇧 United Kingdom (+44)" },
        { "value": "92", "label": "🇵🇰 Pakistan (+92)" },
        { "value": "91", "label": "🇮🇳 India (+91)" },
        { "value": "971", "label": "🇦🇪 UAE (+971)" },
        { "value": "966", "label": "🇸🇦 Saudi Arabia (+966)" },
        { "value": "974", "label": "🇶🇦 Qatar (+974)" },
        { "value": "965", "label": "🇰🇼 Kuwait (+965)" },
        { "value": "973", "label": "🇧🇭 Bahrain (+973)" },
        { "value": "968", "label": "🇴🇲 Oman (+968)" },
        { "value": "61", "label": "🇦🇺 Australia (+61)" },
        { "value": "49", "label": "🇩🇪 Germany (+49)" },
        { "value": "33", "label": "🇫🇷 France (+33)" },
        { "value": "39", "label": "🇮🇹 Italy (+39)" },
        { "value": "34", "label": "🇪🇸 Spain (+34)" },
        { "value": "31", "label": "🇳🇱 Netherlands (+31)" },
        { "value": "90", "label": "🇹🇷 Turkey (+90)" },
        { "value": "20", "label": "🇪🇬 Egypt (+20)" },
        { "value": "27", "label": "🇿🇦 South Africa (+27)" },
        { "value": "234", "label": "🇳🇬 Nigeria (+234)" },
        { "value": "254", "label": "🇰🇪 Kenya (+254)" },
        { "value": "55", "label": "🇧🇷 Brazil (+55)" },
        { "value": "52", "label": "🇲🇽 Mexico (+52)" },
        { "value": "57", "label": "🇨🇴 Colombia (+57)" },
        { "value": "60", "label": "🇲🇾 Malaysia (+60)" },
        { "value": "65", "label": "🇸🇬 Singapore (+65)" },
        { "value": "62", "label": "🇮🇩 Indonesia (+62)" },
        { "value": "63", "label": "🇵🇭 Philippines (+63)" },
        { "value": "66", "label": "🇹🇭 Thailand (+66)" },
        { "value": "880", "label": "🇧🇩 Bangladesh (+880)" },
        { "value": "94", "label": "🇱🇰 Sri Lanka (+94)" },
        { "value": "977", "label": "🇳🇵 Nepal (+977)" }
      ],
      "default": "1-us"
    },
    {
      "id": "whatsapp_number",
      "type": "text",
      "label": "WhatsApp Number",
      "info": "Enter your number without country code or + symbol. Example: 3001234567"
    },
    {
      "id": "pre_filled_message",
      "type": "textarea",
      "label": "Pre-filled Message",
      "info": "This message will appear in WhatsApp when a customer opens the chat",
      "default": "Hello! I have a question about your store."
    },
    {
      "type": "header",
      "content": "Welcome Popup"
    },
    {
      "id": "show_popup",
      "type": "checkbox",
      "label": "Show Welcome Popup",
      "info": "Show a popup when customer clicks the button instead of opening WhatsApp directly",
      "default": false
    },
    {
      "id": "popup_greeting",
      "type": "text",
      "label": "Greeting Name",
      "info": "Name shown at top of popup. Example: Store name or agent name",
      "default": "Hi there! 👋"
    },
    {
      "id": "popup_message",
      "type": "textarea",
      "label": "Popup Message",
      "info": "Message shown in the popup before customer starts chat",
      "default": "How can we help you today? Click below to start a chat on WhatsApp."
    },
    {
      "id": "popup_button_text",
      "type": "text",
      "label": "Chat Button Text",
      "default": "Start Chat on WhatsApp"
    },
    {
      "id": "popup_avatar_emoji",
      "type": "select",
      "label": "Avatar",
      "info": "Emoji shown as the agent avatar in the popup",
